XU2 in0 gate1 sv0_1 MEMCAP
XU3 in0 gate2 sv0_2 MEMCAP
XU4 in1 gate0 sv1_0 MEMCAP
XU5 in1 gate1 sv1_1 MEMCAP
XU6 in1 gate2 sv1_2 MEMCAP
XU7 in2 gate0 sv2_0 MEMCAP
XU8 in2 gate1 sv2_1 MEMCAP
XU9 in2 gate2 sv2_2 MEMCAP
CCs0 gate0 src0 5e-11
CCj0 drn0 0 5e-12
MM1 drn0 gate0 src0 0 NMOS
RRsrc src0 0 0.001
CCs1 gate1 src1 5e-11
CCj1 drn1 0 5e-12
MM2 drn1 gate1 src1 0 NMOS
RRt1 drn0 src1 1
