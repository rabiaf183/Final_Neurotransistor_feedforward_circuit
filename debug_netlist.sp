.title Single Neurotransistor

.SUBCKT MEMCAP TE BE SV

.param Ar=4.7447e-8 As=1.1253e-8 Br=2.6831 Bs=9.3348
.param c1=2.9457e-4 c2=57414 c3=11103 Rp=8e6 Rs=278 Cp=10p
.param wc=1000 xon=0.1 xoff=0.284

.func G(x,Vm) {Ar*x*exp(Br*sgn(Vm)*sqrt(abs(Vm)/x))+As*x*exp(-Bs*sgn(Vm)*sqrt(abs(Vm)))}
.func win_off(x) {-exp((x-xoff)*wc)}
.func win_on(x) {-exp(-(x-xon)*wc)}
.func F(Vm,x) {c1*(exp(c2*x*Vm*G(x,Vm)+win_off(x))-exp(-c3*x*Vm*G(x,Vm)+win_on(x)))}

Cx SV 0 1
Gx 0 SV value={F(V(IE,BE),V(SV,0))}
Gmem IE BE value={V(IE,BE)*G(V(SV,0),V(IE,BE))}
Rms TE IE {Rs}
Rmp IE BE {Rp}
Cmp TE BE {Cp}

.ENDS MEMCAP
.options reltol=1e-3 gmin=1e-12 method=gear
.ic v(sv0_0)=0.15 v(sv0_1)=0.1 v(sv0_2)=0.2 v(sv1_0)=0.1 v(sv1_1)=0.2 v(sv1_2)=0.2 v(sv2_0)=0.1 v(sv2_1)=0.1 v(sv2_2)=0.2 v(gate0)=0 v(gate1)=0 v(gate2)=0 v(rout_node)=0.8 v(vout_node)=0
VDD vdd 0 1.0
